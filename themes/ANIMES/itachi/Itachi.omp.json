//By: OdevMatheus

{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "template": "\u256d\u2500[<#FF0000>🐦‍⬛ </><#FFFFFF>{{ .UserName }}</><#888888>@</><#FF0000>{{ .HostName }}</>]\u2500",
          "type": "session"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>[🪶  </><#FFFFFF>{{ .Path }}</><#FF0000>]</>",
          "type": "path"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>\u2500(</><#FFFFFF>⚡</><#FF0000>)</>",
          "type": "root"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#FF0000",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": " <#FF0000>\ue5fa</> ",
            "yarn_icon": " <#FFFFFF>\ue6a7</>"
          },
          "style": "plain",
          "template": "<#FF0000>(</>{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}<#FF0000>)</>",
          "type": "node"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "python"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "java"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "dotnet"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "go"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "rust"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "dart"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "angular"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "aurelia"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "nx"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "julia"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "ruby"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<#FF0000>)</>",
          "type": "azfunc"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{.Profile}}{{if .Region}}@{{.Region}}{{end}}<#FF0000>)</>",
          "type": "aws"
        },
        {
          "foreground": "#FF0000",
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}<#FF0000>)</>",
          "type": "kubectl"
        },
        {
          "foreground": "#FF0000",
          "options": {
            "linux": "<#FFFFFF>\ue27f</>",
            "macos": "<#FFFFFF>\ue27f</>",
            "windows": "<#FFFFFF>\ue27f</>"
          },
          "style": "plain",
          "template": "<#FF0000>(</><#FFFFFF>{{ if .WSL }}WSL at {{ end }}{{.Icon}}</><#FF0000>)\u2500</>",
          "type": "os"
        },
        {
          "foreground": "#FFFFFF",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}#FF0000{{end}}",
            "{{if eq \"Discharging\" .State.String}}#FFFFFF{{end}}",
            "{{if eq \"Full\" .State.String}}#FF0000{{end}}"
          ],
          "options": {
            "charged_icon": "\uf240 ",
            "charging_icon": "\uf1e6 ",
            "discharging_icon": "\ue234 "
          },
          "style": "plain",
          "template": "<#FF0000>[</><#FFFFFF>{{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}%</><#FF0000>]\u2500</>",
          "type": "battery"
        },
        {
          "foreground": "#FFFFFF",
          "style": "plain",
          "template": "<#FF0000>[</><#FFFFFF>🌙 {{ .CurrentDate | date .Format }}</><#FF0000>]</>",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "style": "plain",
          "foreground": "#FF0000",
          "template": "\u2570\u2500",
          "type": "text"
        },
        {
          "foreground": "#FF0000",
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#FF0000>[</><#FFFFFF>{{ .HEAD }}</>{{ if .Staging.Changed }}<#FFFFFF> \u25cf {{ .Staging.String }}</>{{ end }}{{ if .Working.Changed }}<#FF0000> \u25cf {{ .Working.String }}</>{{ end }}<#FF0000>]-</>",
          "type": "git"
        },
        {
          "foreground": "#FF0000",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FFFFFF{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "🔴 ❯ ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ]
}